@page "/dynamic-routing"
@implements IDisposable
@inject ApiService Api
@inject LocalizationService L
@inject AuthService Auth
@inject ISnackbar Snackbar

@using System.Text.Json

<PageTitle>@L["routing.title"] · OpenClaw</PageTitle>

@if (!Auth.HasRole("admin"))
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="my-4">
        @L["auth.notAuthenticated"]
    </MudAlert>
    return;
}

<div class="dr-shell">
    <header class="dr-hero">
        <div class="dr-hero__crumb">
            <span class="dr-hero__index">03</span>
            <span class="dr-hero__slash">/</span>
            <span class="dr-hero__crumb-text">routing · dynamic turn control</span>
        </div>
        <h1 class="dr-hero__title">@L["routing.title"]</h1>
        <p class="dr-hero__lead">@L["routing.subtitle"]</p>

        <div class="dr-hero__rail">
            <MudButton StartIcon="@Icons.Material.Filled.Refresh"
                       Variant="Variant.Outlined"
                       Color="Color.Default"
                       Disabled="_loading"
                       OnClick="LoadData"
                       Class="dr-btn dr-btn--ghost">
                @L["common.refresh"]
            </MudButton>
        </div>
    </header>

    @if (_loading && !_hasLoaded)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Rounded="true" Class="mb-4" />
    }

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-4">
            @_error
        </MudAlert>
    }

    <div class="dr-grid">
        <article class="dr-metric" style="--metric-accent:#8b5cf6;">
            <div class="dr-metric__label">@L["routing.defaultProfile"]</div>
            <div class="dr-metric__value">@(_defaultProfileId ?? "—")</div>
            <div class="dr-metric__hint">@L["routing.routeContract"]</div>
        </article>

        <article class="dr-metric" style="--metric-accent:#22d3ee;">
            <div class="dr-metric__label">@L["routing.profileCount"]</div>
            <div class="dr-metric__value">@_profileCount</div>
            <div class="dr-metric__hint">@L["routing.profileInventory"]</div>
        </article>

        <article class="dr-metric" style="--metric-accent:#34d399;">
            <div class="dr-metric__label">@L["routing.dynamicRoutes"]</div>
            <div class="dr-metric__value">@_dynamicRouteCount</div>
            <div class="dr-metric__hint">@L["routing.routeHealth"]</div>
        </article>

        <article class="dr-metric" style="--metric-accent:#f59e0b;">
            <div class="dr-metric__label">@L["routing.policyCount"]</div>
            <div class="dr-metric__value">@_policyCount</div>
            <div class="dr-metric__hint">@L["routing.policyRules"]</div>
        </article>

        <MudPaper Class="dr-panel dr-panel--wide" Elevation="0">
            <div class="dr-panel__head">
                <span class="dr-eyebrow">A · @L["routing.routeContract"]</span>
                <span class="dr-panel__rule"></span>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">
                    @L["routing.title"]
                </MudChip>
            </div>
            <div class="dr-panel__body">
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Timeline">
                    @L["routing.routeContractBody"]
                </MudAlert>
                <div class="dr-contract-grid">
                    <div class="dr-contract-item">
                        <div class="dr-contract-item__label">@L["routing.defaultProfile"]</div>
                        <div class="dr-contract-item__value">@(_defaultProfileId ?? "—")</div>
                    </div>
                    <div class="dr-contract-item">
                        <div class="dr-contract-item__label">@L["routing.profileInventory"]</div>
                        <div class="dr-contract-item__value">@_profileCount</div>
                    </div>
                    <div class="dr-contract-item">
                        <div class="dr-contract-item__label">@L["routing.routeHealth"]</div>
                        <div class="dr-contract-item__value">@_routeCount</div>
                    </div>
                    <div class="dr-contract-item">
                        <div class="dr-contract-item__label">@L["routing.policyRules"]</div>
                        <div class="dr-contract-item__value">@_policyCount</div>
                    </div>
                </div>
            </div>
        </MudPaper>

        <MudPaper Class="dr-panel dr-panel--wide" Elevation="0">
            <div class="dr-panel__head">
                <span class="dr-eyebrow">B · @L["routing.profileInventory"]</span>
                <span class="dr-panel__rule"></span>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary">JSON</MudChip>
            </div>
            <div class="dr-panel__body dr-panel__body--flush">
                <MudTable T="JsonElement"
                          Items="_profiles"
                          Dense="true"
                          Hover="true"
                          Bordered="false"
                          Striped="true"
                          Elevation="0">
                    <HeaderContent>
                        <MudTh>@L["routing.profileId"]</MudTh>
                        <MudTh>@L["routing.providerModel"]</MudTh>
                        <MudTh>@L["routing.status"]</MudTh>
                        <MudTh>@L["routing.capabilities"]</MudTh>
                        <MudTh>@L["routing.tags"]</MudTh>
                        <MudTh>@L["routing.fallbacks"]</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="@L["routing.profileId"]">
                            <div class="dr-id">@ReadString(context, "id")</div>
                            @if (!string.IsNullOrWhiteSpace(ReadString(context, "presetId")))
                            {
                                <div class="dr-sub">@ReadString(context, "presetId")</div>
                            }
                        </MudTd>
                        <MudTd DataLabel="@L["routing.providerModel"]">
                            <div class="dr-stack">
                                <span>@ReadString(context, "providerId")</span>
                                <span>@ReadString(context, "modelId")</span>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="@L["routing.status"]">
                            <div class="dr-chiprow">
                                @if (ReadBool(context, "isDefault"))
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary">@L["routing.default"]</MudChip>
                                }
                                @if (ReadBool(context, "isAvailable"))
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Success">@L["routing.available"]</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error">@L["common.disabled"]</MudChip>
                                }
                                @if (ReadBool(context, "isImplicit"))
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Tertiary">@L["routing.implicit"]</MudChip>
                                }
                            </div>
                            @if (ReadStringArray(context, "validationIssues").Count > 0)
                            {
                                <div class="dr-sub dr-sub--warn">@string.Join(" · ", ReadStringArray(context, "validationIssues"))</div>
                            }
                        </MudTd>
                        <MudTd DataLabel="@L["routing.capabilities"]">
                            <div class="dr-chiprow">
                                @foreach (var capability in BuildCapabilityLabels(context))
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary">@capability</MudChip>
                                }
                            </div>
                        </MudTd>
                        <MudTd DataLabel="@L["routing.tags"]">
                            <div class="dr-chiprow">
                                @foreach (var tag in ReadStringArray(context, "tags"))
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">@tag</MudChip>
                                }
                            </div>
                        </MudTd>
                        <MudTd DataLabel="@L["routing.fallbacks"]">
                            <div class="dr-chiprow">
                                @foreach (var fallback in ReadStringArray(context, "fallbackProfileIds"))
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Tertiary">@fallback</MudChip>
                                }
                            </div>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <div class="dr-empty">@L["common.noData"]</div>
                    </NoRecordsContent>
                </MudTable>
            </div>
        </MudPaper>

        <MudPaper Class="dr-panel dr-panel--wide" Elevation="0">
            <div class="dr-panel__head">
                <span class="dr-eyebrow">C · @L["routing.routeHealth"]</span>
                <span class="dr-panel__rule"></span>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success">@_dynamicRouteCount dynamic</MudChip>
            </div>
            <div class="dr-panel__body dr-panel__body--flush">
                <MudTable T="JsonElement"
                          Items="_routes"
                          Dense="true"
                          Hover="true"
                          Bordered="false"
                          Striped="true"
                          Elevation="0">
                    <HeaderContent>
                        <MudTh>@L["routing.route"]</MudTh>
                        <MudTh>@L["routing.status"]</MudTh>
                        <MudTh>@L["routing.metrics"]</MudTh>
                        <MudTh>@L["routing.tags"]</MudTh>
                        <MudTh>@L["routing.validationIssues"]</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="@L["routing.route"]">
                            <div class="dr-stack">
                                <span>@ReadString(context, "profileId")</span>
                                <span>@(string.Concat(ReadString(context, "providerId"), "/", ReadString(context, "modelId")))</span>
                            </div>
                            <div class="dr-chiprow dr-chiprow--tight">
                                @if (ReadBool(context, "isDefaultRoute"))
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary">@L["routing.default"]</MudChip>
                                }
                                @if (ReadBool(context, "isDynamic"))
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Success">@L["routing.dynamic"]</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">@L["routing.static"]</MudChip>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(ReadString(context, "ownerId")))
                            {
                                <div class="dr-sub">@L["routing.owner"]: @ReadString(context, "ownerId")</div>
                            }
                        </MudTd>
                        <MudTd DataLabel="@L["routing.status"]">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@CircuitColor(ReadString(context, "circuitState"))">
                                @ReadString(context, "circuitState")
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="@L["routing.metrics"]">
                            <div class="dr-sub">@L["routing.requests"]: @ReadLong(context, "requests")</div>
                            <div class="dr-sub">@L["routing.errors"]: @ReadLong(context, "errors")</div>
                            @if (ReadLong(context, "retries") > 0)
                            {
                                <div class="dr-sub">Retries: @ReadLong(context, "retries")</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(ReadString(context, "lastError")))
                            {
                                <div class="dr-sub dr-sub--warn">@ReadString(context, "lastError")</div>
                            }
                        </MudTd>
                        <MudTd DataLabel="@L["routing.tags"]">
                            <div class="dr-chiprow">
                                @foreach (var tag in ReadStringArray(context, "tags"))
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">@tag</MudChip>
                                }
                            </div>
                        </MudTd>
                        <MudTd DataLabel="@L["routing.validationIssues"]">
                            @if (ReadStringArray(context, "validationIssues").Count == 0)
                            {
                                <span class="dr-sub">@L["routing.noIssues"]</span>
                            }
                            else
                            {
                                <div class="dr-sub dr-sub--warn">@string.Join(" · ", ReadStringArray(context, "validationIssues"))</div>
                            }
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <div class="dr-empty">@L["common.noData"]</div>
                    </NoRecordsContent>
                </MudTable>
            </div>
        </MudPaper>

        <MudPaper Class="dr-panel dr-panel--wide" Elevation="0">
            <div class="dr-panel__head">
                <span class="dr-eyebrow">D · @L["routing.policyRules"]</span>
                <span class="dr-panel__rule"></span>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning">Policy</MudChip>
            </div>
            <div class="dr-panel__body dr-panel__body--flush">
                <MudTable T="JsonElement"
                          Items="_policies"
                          Dense="true"
                          Hover="true"
                          Bordered="false"
                          Striped="true"
                          Elevation="0">
                    <HeaderContent>
                        <MudTh>ID</MudTh>
                        <MudTh>@L["routing.priority"]</MudTh>
                        <MudTh>@L["routing.providerModel"]</MudTh>
                        <MudTh>@L["routing.constraints"]</MudTh>
                        <MudTh>@L["routing.tokenLimits"]</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="ID">
                            <div class="dr-id">@ReadString(context, "id")</div>
                            <div class="dr-chiprow dr-chiprow--tight">
                                @if (ReadBool(context, "enabled"))
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Success">@L["common.enabled"]</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error">@L["common.disabled"]</MudChip>
                                }
                            </div>
                        </MudTd>
                        <MudTd DataLabel="@L["routing.priority"]">@ReadLong(context, "priority")</MudTd>
                        <MudTd DataLabel="@L["routing.providerModel"]">
                            <div class="dr-stack">
                                <span>@ReadString(context, "providerId")</span>
                                <span>@ReadString(context, "modelId")</span>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="@L["routing.constraints"]">
                            <div class="dr-sub">@L["routing.channel"]: @ReadString(context, "channelId")</div>
                            <div class="dr-sub">@L["routing.sender"]: @ReadString(context, "senderId")</div>
                            <div class="dr-sub">@L["routing.session"]: @ReadString(context, "sessionId")</div>
                            <div class="dr-chiprow dr-chiprow--tight">
                                @foreach (var fallback in ReadStringArray(context, "fallbackModels"))
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Tertiary">@fallback</MudChip>
                                }
                            </div>
                        </MudTd>
                        <MudTd DataLabel="@L["routing.tokenLimits"]">
                            <div class="dr-sub">Input: @ReadLong(context, "maxInputTokens")</div>
                            <div class="dr-sub">Output: @ReadLong(context, "maxOutputTokens")</div>
                            <div class="dr-sub">Total: @ReadLong(context, "maxTotalTokens")</div>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <div class="dr-empty">@L["common.noData"]</div>
                    </NoRecordsContent>
                </MudTable>
            </div>
        </MudPaper>
    </div>
</div>

<style>
    .dr-shell {
        display: flex;
        flex-direction: column;
        gap: 28px;
        padding: 8px 4px 48px;
        max-width: 1480px;
        margin: 0 auto;
    }

    .dr-hero {
        position: relative;
        padding: 26px 32px 28px;
        border-radius: 24px;
        background:
            radial-gradient(720px 320px at 0% 0%, rgba(56, 189, 248, 0.16), transparent 60%),
            radial-gradient(720px 320px at 100% 100%, rgba(139, 92, 246, 0.14), transparent 65%),
            linear-gradient(180deg, rgba(20, 26, 50, 0.55), rgba(11, 16, 32, 0.4));
        border: 1px solid rgba(148, 163, 184, 0.18);
        overflow: hidden;
    }

    .dr-hero__crumb {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--mud-palette-text-secondary);
        font-family: 'JetBrains Mono', Consolas, monospace;
        font-size: 0.74rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
    }

    .dr-hero__index { color: #38bdf8; }
    .dr-hero__title { margin: 14px 0 6px; font-size: clamp(2rem, 4vw, 3.25rem); font-weight: 700; letter-spacing: -0.04em; }
    .dr-hero__lead { margin: 0; max-width: 72ch; color: var(--mud-palette-text-secondary); font-size: 1rem; line-height: 1.6; }
    .dr-hero__rail { margin-top: 20px; display: flex; gap: 12px; flex-wrap: wrap; }

    .dr-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1rem;
    }

    .dr-metric {
        position: relative;
        padding: 18px 18px 20px;
        border-radius: 18px;
        background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
        border: 1px solid var(--mud-palette-lines-default);
        overflow: hidden;
    }

    .dr-metric::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(300px 120px at top left, color-mix(in srgb, var(--metric-accent) 22%, transparent), transparent 60%);
        pointer-events: none;
    }

    .dr-metric__label, .dr-contract-item__label {
        font-family: 'JetBrains Mono', Consolas, monospace;
        font-size: 0.72rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--mud-palette-text-secondary);
        position: relative;
        z-index: 1;
    }

    .dr-metric__value {
        margin-top: 10px;
        font-size: 1.4rem;
        font-weight: 700;
        letter-spacing: -0.03em;
        position: relative;
        z-index: 1;
        word-break: break-word;
    }

    .dr-metric__hint { margin-top: 8px; color: var(--mud-palette-text-secondary); font-size: 0.9rem; position: relative; z-index: 1; }

    .dr-panel {
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 18px;
        overflow: hidden;
        background: var(--mud-palette-surface);
    }

    .dr-panel--wide { grid-column: 1 / -1; }

    .dr-panel__head {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.95rem 1.1rem;
        border-bottom: 1px solid var(--mud-palette-lines-default);
        background: linear-gradient(180deg, rgba(56,189,248,0.04), transparent);
    }

    .dr-panel__rule { flex: 1; height: 1px; background: linear-gradient(90deg, rgba(148,163,184,0.25), transparent); }

    .dr-panel__body { padding: 1.1rem; display: flex; flex-direction: column; gap: 1rem; }
    .dr-panel__body--flush { padding: 0; }

    .dr-eyebrow {
        font-family: 'JetBrains Mono', Consolas, monospace;
        font-size: 0.72rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--mud-palette-text-secondary);
    }

    .dr-contract-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 0.75rem;
    }

    .dr-contract-item {
        padding: 0.95rem 1rem;
        border-radius: 14px;
        border: 1px solid var(--mud-palette-lines-default);
        background: rgba(255,255,255,0.02);
    }

    .dr-contract-item__value, .dr-id, .dr-stack span:first-child { font-weight: 700; letter-spacing: -0.01em; }
    .dr-contract-item__value { margin-top: 6px; word-break: break-word; }

    .dr-stack { display: flex; flex-direction: column; gap: 0.15rem; }
    .dr-sub { color: var(--mud-palette-text-secondary); font-size: 0.85rem; margin-top: 0.2rem; word-break: break-word; }
    .dr-sub--warn { color: var(--mud-palette-warning); }

    .dr-chiprow { display: flex; flex-wrap: wrap; gap: 0.35rem; }
    .dr-chiprow--tight { margin-top: 0.35rem; }

    .dr-empty {
        padding: 2rem;
        text-align: center;
        color: var(--mud-palette-text-secondary);
        font-family: 'JetBrains Mono', Consolas, monospace;
        font-size: 0.85rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }
</style>

@code {
    private JsonElement? _providerState;
    private string? _defaultProfileId;
    private List<JsonElement> _profiles = new();
    private List<JsonElement> _routes = new();
    private List<JsonElement> _policies = new();
    private bool _loading = true;
    private bool _hasLoaded;
    private string? _error;

    private int _profileCount;
    private int _routeCount;
    private int _dynamicRouteCount;
    private int _policyCount;

    protected override async Task OnInitializedAsync()
    {
        L.OnLanguageChanged += HandleLanguageChanged;
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            _providerState = await TryGetJsonAsync("admin/providers").ConfigureAwait(false);
            _defaultProfileId = ReadString(_providerState, "modelProfiles", "defaultProfileId");
            _profiles = ReadObjectArray(_providerState, "modelProfiles", "profiles");
            _routes = ReadObjectArray(_providerState, "routes");
            _policies = ReadObjectArray(_providerState, "policies");

            _profileCount = _profiles.Count;
            _routeCount = _routes.Count;
            _dynamicRouteCount = _routes.Count(route => ReadBool(route, "isDynamic"));
            _policyCount = _policies.Count;
            _hasLoaded = true;
        }
        catch
        {
            _error = L["common.error"];
            Snackbar.Add(L["common.error"], Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task<JsonElement?> TryGetJsonAsync(string url)
    {
        using var response = await Api.GetRawAsync(url).ConfigureAwait(false);
        if (!response.IsSuccessStatusCode)
        {
            return null;
        }

        await using var stream = await response.Content.ReadAsStreamAsync().ConfigureAwait(false);
        using var document = await JsonDocument.ParseAsync(stream).ConfigureAwait(false);
        return document.RootElement.Clone();
    }

    private static List<JsonElement> ReadObjectArray(JsonElement? root, params string[] path)
    {
        var element = TryGetProperty(root, path);
        if (element is null || element.Value.ValueKind != JsonValueKind.Array)
        {
            return new List<JsonElement>();
        }

        return element.Value.EnumerateArray().Select(item => item.Clone()).ToList();
    }

    private static JsonElement? TryGetProperty(JsonElement? root, params string[] path)
    {
        if (root is null)
        {
            return null;
        }

        var current = root.Value;
        foreach (var segment in path)
        {
            if (current.ValueKind != JsonValueKind.Object || !current.TryGetProperty(segment, out var next))
            {
                return null;
            }

            current = next;
        }

        return current;
    }

    private static string? ReadString(JsonElement? root, params string[] path)
    {
        var element = TryGetProperty(root, path);
        if (element is null)
        {
            return null;
        }

        return element.Value.ValueKind switch
        {
            JsonValueKind.String => element.Value.GetString(),
            JsonValueKind.Null => null,
            _ => element.Value.ToString()
        };
    }

    private static bool ReadBool(JsonElement? root, params string[] path)
    {
        var element = TryGetProperty(root, path);
        if (element is null)
        {
            return false;
        }

        if (element.Value.ValueKind == JsonValueKind.True || element.Value.ValueKind == JsonValueKind.False)
        {
            return element.Value.GetBoolean();
        }

        return bool.TryParse(element.Value.ToString(), out var result) && result;
    }

    private static long ReadLong(JsonElement? root, params string[] path)
    {
        var element = TryGetProperty(root, path);
        if (element is null)
        {
            return 0;
        }

        if (element.Value.ValueKind == JsonValueKind.Number && element.Value.TryGetInt64(out var number))
        {
            return number;
        }

        return long.TryParse(element.Value.ToString(), out var parsed) ? parsed : 0;
    }

    private static List<string> ReadStringArray(JsonElement? root, params string[] path)
    {
        var element = TryGetProperty(root, path);
        if (element is null || element.Value.ValueKind != JsonValueKind.Array)
        {
            return new List<string>();
        }

        return element.Value.EnumerateArray()
            .Select(item => item.ValueKind == JsonValueKind.String ? item.GetString() : item.ToString())
            .Where(item => !string.IsNullOrWhiteSpace(item))
            .ToList()!;
    }

    private static List<string> BuildCapabilityLabels(JsonElement profile)
    {
        var capabilities = TryGetProperty(profile, "capabilities");
        if (capabilities is null)
        {
            return [];
        }

        var labels = new List<string>();

        if (ReadBool(capabilities, "supportsTools")) labels.Add("tools");
        if (ReadBool(capabilities, "supportsVision")) labels.Add("vision");
        if (ReadBool(capabilities, "supportsStructuredOutputs")) labels.Add("structured");
        if (ReadBool(capabilities, "supportsJsonSchema")) labels.Add("json-schema");
        if (ReadBool(capabilities, "supportsStreaming")) labels.Add("streaming");
        if (ReadBool(capabilities, "supportsReasoningEffort")) labels.Add("reasoning");

        return labels;
    }

    private static Color CircuitColor(string? circuitState)
        => circuitState?.ToLowerInvariant() switch
        {
            "closed" => Color.Success,
            "halfopen" => Color.Warning,
            "half-open" => Color.Warning,
            "open" => Color.Error,
            _ => Color.Default
        };

    private void HandleLanguageChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        L.OnLanguageChanged -= HandleLanguageChanged;
    }
}